@model IEnumerable<CvMatchingSystem.Models.Candidate>

@{
    ViewData["Title"] = "Candidates List";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Candidates</h1>
    <a asp-action="Create" class="btn btn-success">Add New Candidate</a>
</div>

<table class="table table-hover">
    <thead class="table-light">
        <tr>
            <th>Full Name</th>
            <th>Experience</th>
            <th>Resume File</th> <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <strong>@Html.DisplayFor(modelItem => item.FullName)</strong>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ExperienceYears) years
            </td>
            <td>
                @if (!string.IsNullOrEmpty(item.ResumePath))
                {
                    <a href="~/@item.ResumePath" target="_blank" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-file-earmark-pdf"></i> View PDF
                    </a>
                }
                else
                {
                    <span class="badge bg-danger">No File</span>
                }
            </td>
            <td>
                <div class="btn-group" role="group">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </td>
        </tr>
}
    </tbody>
</table>