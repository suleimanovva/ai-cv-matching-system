@model IEnumerable<CvMatchingSystem.Models.Candidate>

@{
    ViewData["Title"] = "Candidates List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Candidates</h1>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-person-plus"></i> Add New Candidate
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Experience</th>
                        <th>Resume File</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <strong>@Html.DisplayFor(modelItem => item.FullName)</strong>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@item.ExperienceYears years</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ResumePath))
                            {
                                <a href="~/@item.ResumePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-file-earmark-pdf"></i> View PDF
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-danger">No File</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>