@model IEnumerable<CvMatchingSystem.Models.Candidate>

@{
    ViewData["Title"] = "Candidates List";
}

<h1>Candidates List</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<table class="table table-hover">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Resume</th>
            <th>Experience (Years)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FullName)
            </td>
            <td>
                @if (!string.IsNullOrEmpty(item.ResumePath))
                {
                    <a href="~/@item.ResumePath" target="_blank" class="btn btn-sm btn-outline-info">
                        View PDF
                    </a>
                }
                else
                {
                    <span class="text-danger">No File</span>
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ExperienceYears)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>