@model CvMatchingSystem.Models.Candidate

@{
    ViewData["Title"] = "Candidate Profile";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">@Model.FullName</h1>
        <div class="pg-meta">Internal Talent Database / ID: @Model.Id</div>
    </div>
    <div style="display:flex; gap:16px; align-items:center;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="tact">edit profile</a>
        <a asp-action="Index" class="tact">← back to directory</a>
    </div>
</div>

<div style="display: grid; grid-template-columns: 320px 1fr; gap: 24px; align-items: start;">
    
    <div class="card" style="padding: 32px; text-align: center;">
        <div style="width: 80px; height: 80px; background: var(--s2); border: 1px solid var(--border); border-radius: 20px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 20px;">
            <span style="font-size: 28px; font-weight: 800; color: var(--p);">@Model.FullName?[0]</span>
        </div>
        
        <h2 style="font-size: 20px; font-weight: 800; color: var(--t1); margin-bottom: 8px;">@Model.FullName</h2>
        
        <div style="margin-bottom: 32px;">
            <span class="chip @(Model.ExperienceYears >= 5 ? "chip-g" : "chip-a")">
                @Model.ExperienceYears years experience
            </span>
        </div>

        <div style="display: grid; gap: 10px;">
            <a asp-controller="Matching" asp-action="Index" class="btn-nexus" style="justify-content: center; padding: 12px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                Run AI Match
            </a>
        </div>
    </div>

    <div class="card" style="min-height: 700px;">
        <div class="ch" style="padding: 16px 20px; background: var(--s2); border-bottom: 1px solid var(--border);">
            <div class="ch-label">Document Intelligence</div>
            @if (!string.IsNullOrEmpty(Model.ResumePath))
            {
                <a href="~/@Model.ResumePath" download class="tact" style="color:var(--p) !important">download pdf</a>
            }
        </div>
        
        <div style="height: 100%; min-height: 650px;">
            @if (!string.IsNullOrEmpty(Model.ResumePath))
            {
                <iframe src="@Url.Content("~/" + Model.ResumePath)" width="100%" height="650px" style="border: none; display: block;"></iframe>
            }
            else
            {
                <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 500px; color: var(--t3);">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 16px; opacity: 0.5;">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/>
                    </svg>
                    <p style="font-family: var(--mono); font-size: 11px;">No digital resume attached to this profile.</p>
                </div>
            }
        </div>
    </div>
</div>