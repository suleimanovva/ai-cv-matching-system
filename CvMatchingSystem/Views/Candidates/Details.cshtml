@model CvMatchingSystem.Models.Candidate

@{
    ViewData["Title"] = "Profile: " + Model.FullName;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                        @Model.FullName?[0]
                    </div>
                    <h3 class="fw-bold">@Model.FullName</h3>
                    <p class="text-muted"><i class="bi bi-briefcase"></i> Experience: @Model.ExperienceYears Years</p>
                    <hr>
                    <div class="d-grid gap-2">
                        <a asp-controller="Matching" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-magic"></i> Run AI Match
                        </a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                            <i class="bi bi-pencil"></i> Edit Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-file-pdf text-danger"></i> Resume Preview</span>
                    @if (!string.IsNullOrEmpty(Model.ResumePath))
                    {
                        <a href="~/@Model.ResumePath" download class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-download"></i> Download
                        </a>
                    }
                </div>
                <div class="card-body p-0" style="min-height: 500px;">
                    @if (!string.IsNullOrEmpty(Model.ResumePath))
                    {
                        <iframe src="@Url.Content("~/" + Model.ResumePath)" width="100%" height="600px" style="border: none;"></iframe>
                    }
                    else
                    {
                        <div class="text-center mt-5 pt-5">
                            <i class="bi bi-file-earmark-x display-1 text-muted"></i>
                            <p class="mt-3">No PDF resume available for this candidate.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>