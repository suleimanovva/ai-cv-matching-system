@model CvMatchingSystem.Models.Candidate

@{
    ViewData["Title"] = "Edit Candidate";
}

<h1>Edit</h1>
<h4>Candidate</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Id" />
            
            <input type="hidden" asp-for="ResumePath" />

            <div class="form-group mb-3">
                <label asp-for="FullName" class="control-label">Full Name</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label d-block">Current Resume</label>
                @if (!string.IsNullOrEmpty(Model.ResumePath))
                {
                    <a href="~/@Model.ResumePath" target="_blank" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-file-earmark-pdf"></i> View Current PDF
                    </a>
                }
                else
                {
                    <span class="badge bg-warning text-dark">No file uploaded yet</span>
                }
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Upload New Resume (Optional)</label>
                <input asp-for="ResumeFile" type="file" class="form-control" accept=".pdf" />
                <small class="text-muted">Leave empty to keep the current resume.</small>
                <span asp-validation-for="ResumeFile" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ExperienceYears" class="control-label">Years of Experience</label>
                <input asp-for="ExperienceYears" class="form-control" type="number" />
                <span asp-validation-for="ExperienceYears" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}