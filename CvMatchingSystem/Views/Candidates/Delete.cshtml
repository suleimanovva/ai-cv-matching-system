@model CvMatchingSystem.Models.Candidate

@{
    ViewData["Title"] = "Remove Candidate";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">Delete Profile</h1>
        <div class="pg-meta">Internal Database ID: @Model.Id</div>
    </div>
    <a asp-action="Index" class="tact" style="text-decoration:none;">← Cancel</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto; border-color: var(--red);">
    <div class="ch" style="background: var(--red-bg); border-bottom-color: var(--red);">
        <div class="ch-label" style="color: var(--red);">Action Required: Permanent Deletion</div>
    </div>

    <div style="padding: 32px;">
        <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 24px; color: var(--t1);">
            Are you sure you want to remove this candidate?
        </h3>

        <div style="background: var(--s2); border: 1px solid var(--border); border-radius: 10px; padding: 20px; margin-bottom: 32px;">
            <div style="margin-bottom: 12px;">
                <span class="stat-label" style="font-size: 9px;">Full Name</span>
                <div style="font-size: 16px; font-weight: 700; color: var(--t1);">@Model.FullName</div>
            </div>
            <div style="margin-bottom: 12px;">
                <span class="stat-label" style="font-size: 9px;">Experience</span>
                <div style="font-family: var(--mono); font-size: 13px; color: var(--p);">@Model.ExperienceYears Years</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.ResumePath))
            {
                <div>
                    <span class="stat-label" style="font-size: 9px;">Attached File</span>
                    <div style="font-size: 12px; color: var(--t3); font-family: var(--mono);">@Model.ResumePath</div>
                </div>
            }
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
                <button type="submit" class="btn-nexus" style="background: var(--red); color: #fff; border: none; justify-content: center; padding: 14px; font-size: 14px;">
                    Confirm and Delete
                </button>
                <a asp-action="Index" class="tact" style="text-align: center; padding: 8px; text-decoration: none;">Keep this profile</a>
            </div>
        </form>
    </div>
</div>