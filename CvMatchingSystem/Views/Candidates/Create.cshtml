@model CvMatchingSystem.Models.Candidate

@{
    ViewData["Title"] = "Create Candidate";
}

<div class="container mt-4">
    <h1>Create Candidate</h1>
    <h4>Add a new candidate for AI analysis</h4>
    <hr />
    
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group mb-3">
                    <label asp-for="FullName" class="control-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="e.g. Alex Chen" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Resume (PDF only)</label>
                    <input name="ResumeFile" type="file" class="form-control" accept=".pdf" required />
                    <span asp-validation-for="ResumePath" class="text-danger"></span>
                    <small class="text-muted d-block mt-1">Maximum file size: 5MB. Only PDF files are supported.</small>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ExperienceYears" class="control-label">Years of Experience</label>
                    <input asp-for="ExperienceYears" class="form-control" type="number" min="0" required />
                    <span asp-validation-for="ExperienceYears" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">Create Candidate</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}