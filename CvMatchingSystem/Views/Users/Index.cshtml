@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Staff Control";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">User Management</h1>
        <div class="pg-meta">@Model.Count() authorized HR accounts</div>
    </div>
    <a asp-action="Create" class="btn-nexus">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add New Employee
    </a>
</div>

<div class="card c-table">
    <div class="ch">
        <div class="ch-label">System Personnel</div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Email Address</th>
                <th>Access Level</th>
                <th style="text-align:right">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var roles = await UserManager.GetRolesAsync(user);
                var primaryRole = roles.FirstOrDefault() ?? "No Role";
                <tr>
                    <td>
                        <div class="cn">@user.Email</div>
                    </td>
                    <td>
                        @if (primaryRole == "Admin")
                        {
                            <span class="chip chip-b" style="background:var(--red-bg); color:var(--red);">@primaryRole</span>
                        }
                        else
                        {
                            <span class="chip chip-a">@primaryRole</span>
                        }
                    </td>
                    <td style="text-align:right">
                        <div style="display:flex; gap:12px; justify-content:flex-end;">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="tact">edit</a>
                            <a asp-action="Delete" asp-route-id="@user.Id" class="tact" style="color:var(--red) !important">revoke</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>