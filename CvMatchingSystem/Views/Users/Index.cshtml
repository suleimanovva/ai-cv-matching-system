@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> User Management</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add New Employee</a>
    </div>

    <table class="table table-hover shadow-sm bg-white">
        <thead class="table-dark">
            <tr>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var roles = await UserManager.GetRolesAsync(user);
                <tr>
                    <td>@user.Email</td>
                    <td>
                        <span class="badge @(roles.Contains("Admin") ? "bg-danger" : "bg-info text-dark")">
                            @(roles.FirstOrDefault() ?? "No Role")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" disabled>Edit</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>