<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus AI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-logo">
            <svg class="logo-svg" viewBox="0 0 16 16" fill="none">
                <rect x="2" y="2" width="5" height="5" rx="1.2" fill="white" opacity=".9"/>
                <rect x="9" y="2" width="5" height="5" rx="1.2" fill="white" opacity=".6"/>
                <rect x="2" y="9" width="5" height="5" rx="1.2" fill="white" opacity=".6"/>
                <rect x="9" y="9" width="5" height="5" rx="1.2" fill="white" opacity=".35"/>
            </svg>
        </div>

        <nav class="nav-menu">
            <a asp-controller="Home" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <span class="nav-pip"></span>
                <span class="nav-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></span>
                <span class="nav-text">Dashboard</span>
            </a>
            <a asp-controller="Candidates" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Candidates" ? "active" : "")">
                <span class="nav-pip"></span>
                <span class="nav-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
                <span class="nav-text">Candidates</span>
            </a>
            <a asp-controller="JobPostings" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "JobPostings" ? "active" : "")">
                <span class="nav-pip"></span>
                <span class="nav-icon"><svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></span>
                <span class="nav-text">Job Postings</span>
            </a>
            <a asp-controller="Matching" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Matching" ? "active" : "")">
                <span class="nav-pip"></span>
                <span class="nav-icon"><svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span>
                <span class="nav-text">AI Matching</span>
            </a>
            
            <div class="nav-divider"></div>
            
            <a asp-controller="Results" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Results" ? "active" : "")">
                <span class="nav-pip"></span>
                <span class="nav-icon"><svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span>
                <span class="nav-text">Results History</span>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-divider"></div>
                <div style="padding: 10px 24px; font-size: 10px; text-transform: uppercase; color: var(--t3); letter-spacing: 0.1em; font-weight: 700;">System</div>
                <a asp-controller="Users" asp-action="Index" class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active" : "")">
                    <span class="nav-pip"></span>
                    <span class="nav-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
                    <span class="nav-text">Staff Management</span>
                </a>
            }
        </nav>

        <div class="sidebar-bottom">
            <div style="display: flex; flex-direction: column; gap: 12px; width: 100%;">
                <div class="avatar-wrap" style="align-self: center;"><div class="avatar-initials">NS</div></div>
                <form asp-controller="Account" asp-action="Logout" method="post" style="width: 100%;">
                    <button type="submit" class="tact" style="width: 100%; border: none; background: transparent; text-align: left; padding-left: 24px; font-size: 11px;">
                        Sign Out
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <main class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <h1 class="page-name">@ViewData["Title"]</h1>
                <div class="topbar-sep"></div>
                <div class="breadcrumb-text">@(ViewContext.RouteData.Values["Controller"]?.ToString()?.ToLower() ?? "dashboard")</div>
            </div>
            <a asp-controller="JobPostings" asp-action="Create" class="btn-nexus">
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                New Posting
            </a>
        </header>

        <div class="content-area">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>