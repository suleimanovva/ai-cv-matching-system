@model CvMatchingSystem.Models.JobPosting

@{
    ViewData["Title"] = "New Position";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">Create Posting</h1>
        <div class="pg-meta">Define requirements for AI discovery</div>
    </div>
    <a asp-action="Index" class="tact" style="text-decoration:none;">← Back to Listings</a>
</div>

<div class="card" style="max-width: 640px; margin: 0 auto;">
    <div class="ch">
        <div class="ch-label">Position Requirements</div>
    </div>

    <div style="padding: 28px;">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size: 12px; margin-bottom: 20px;"></div>

            <div style="margin-bottom: 22px;">
                <label asp-for="Title" class="stat-label" style="display:block; margin-bottom:8px;">Job Title</label>
                <input asp-for="Title" placeholder="e.g. Senior Backend Engineer" style="width: 100%; background: var(--s2); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-family: var(--ff); font-size: 14px; outline: none; color: var(--t1);" />
                <span asp-validation-for="Title" class="text-danger" style="font-size: 11px;"></span>
            </div>

            <div style="margin-bottom: 22px;">
                <label asp-for="Requirements" class="stat-label" style="display:block; margin-bottom:8px;">Core Tech Stack</label>
                <textarea asp-for="Requirements" rows="3" placeholder="List keywords for NLP extraction..." style="width: 100%; background: var(--s2); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-family: var(--mono); font-size: 13px; outline: none; color: var(--t2); resize: vertical;"></textarea>
                <span asp-validation-for="Requirements" class="text-danger" style="font-size: 11px;"></span>
            </div>

            <div style="margin-bottom: 22px;">
                <label asp-for="Description" class="stat-label" style="display:block; margin-bottom:8px;">Role Summary</label>
                <textarea asp-for="Description" rows="5" style="width: 100%; background: var(--s2); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-family: var(--ff); font-size: 14px; outline: none; color: var(--t2); resize: vertical;"></textarea>
                <span asp-validation-for="Description" class="text-danger" style="font-size: 11px;"></span>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px;">
                <div>
                    <label asp-for="MinScore" class="stat-label" style="display:block; margin-bottom:8px;">Min. Match %</label>
                    <input asp-for="MinScore" type="number" value="70" style="width: 100%; background: var(--s2); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-family: var(--mono); font-size: 14px; outline: none;" />
                    <span asp-validation-for="MinScore" class="text-danger" style="font-size: 11px;"></span>
                </div>
                <div>
                    <label asp-for="CreatedBy" class="stat-label" style="display:block; margin-bottom:8px;">Hiring Manager</label>
                    <input asp-for="CreatedBy" style="width: 100%; background: var(--s2); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-family: var(--ff); font-size: 14px; outline: none;" />
                    <span asp-validation-for="CreatedBy" class="text-danger" style="font-size: 11px;"></span>
                </div>
            </div>

            <button type="submit" class="btn-nexus" style="width: 100%; justify-content: center; padding: 14px; font-size: 14px;">Publish Position</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}