@model CvMatchingSystem.Models.JobPosting

@{
    ViewData["Title"] = "Remove Position";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">Confirm Deletion</h1>
        <div class="pg-meta">System ID: @Model.Id</div>
    </div>
    <a asp-action="Index" class="tact" style="text-decoration:none;">← Cancel and Back</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto; border-color: var(--red);">
    <div class="ch" style="background: var(--red-bg); border-bottom-color: var(--red);">
        <div class="ch-label" style="color: var(--red);">Warning: Irreversible Action</div>
    </div>

    <div style="padding: 32px;">
        <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 24px; color: var(--t1); text-align: center;">
            Are you sure you want to permanently delete this posting?
        </h3>

        <div style="background: var(--s2); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 32px;">
            <div style="margin-bottom: 16px;">
                <span class="stat-label" style="font-size: 9px;">Position</span>
                <div style="font-size: 16px; font-weight: 700; color: var(--t1);">@Model.Title</div>
            </div>
            <div style="margin-bottom: 16px;">
                <span class="stat-label" style="font-size: 9px;">Required Threshold</span>
                <div style="font-family: var(--mono); font-size: 13px; color: var(--p); font-weight: 700;">@Model.MinScore% Match Required</div>
            </div>
            <div>
                <span class="stat-label" style="font-size: 9px;">Author / Owner</span>
                <div style="font-size: 13px; color: var(--t2);">@Model.CreatedBy</div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
                <button type="submit" class="btn-nexus" style="background: var(--red); color: #fff; border: none; justify-content: center; padding: 14px; font-size: 14px;">
                    Confirm Deletion
                </button>
                <a asp-action="Index" class="tact" style="text-align: center; padding: 8px; text-decoration: none;">Keep this position</a>
            </div>
        </form>
    </div>
</div>