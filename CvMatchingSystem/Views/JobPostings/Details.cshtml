@model CvMatchingSystem.Models.JobPosting

@{
    ViewData["Title"] = "Job Details";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">@Model.Title</h1>
        <div class="pg-meta">System Reference ID: @Model.Id</div>
    </div>
    <div style="display:flex; gap:16px; align-items:center;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-nexus" style="text-decoration:none;">Edit Position</a>
        <a asp-action="Index" class="tact" style="text-decoration:none;">← Back</a>
    </div>
</div>

<div class="card" style="max-width: 800px; margin: 0 auto;">
    <div class="ch">
        <div class="ch-label">Position Specification</div>
    </div>

    <div style="padding: 32px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 32px;">
            <div>
                <span class="stat-label" style="display:block; margin-bottom:8px;">Match Threshold</span>
                <div style="display:flex; align-items:center; gap:10px;">
                    <span class="chip chip-b" style="font-size: 12px; padding: 4px 12px;">@Model.MinScore% Score Required</span>
                </div>
            </div>
            <div>
                <span class="stat-label" style="display:block; margin-bottom:8px;">Posted By</span>
                <div style="font-size: 15px; font-weight: 600; color: var(--t2);">@Model.CreatedBy</div>
            </div>
        </div>

        <div style="margin-bottom: 40px;">
            <span class="stat-label" style="display:block; margin-bottom:12px;">Technical Stack & Requirements</span>
            <div style="background: var(--s2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; font-family: var(--mono); font-size: 13px; color: var(--t2); line-height: 1.7;">
                @Model.Requirements
            </div>
        </div>

        <div>
            <span class="stat-label" style="display:block; margin-bottom:12px;">Full Description</span>
            <div style="font-size: 15px; color: var(--t1); line-height: 1.8; white-space: pre-line;">
                @Model.Description
            </div>
        </div>
    </div>
</div>