@{
    Layout = null;
    ViewData["Title"] = "Welcome";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus</title>
    <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@300;400;500;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    <style>
        :root {
            --bg: #f0ede8; --s1: #faf8f5; --s2: #f5f2ed; --border: #e2ddd6;
            --t1: #1a1714; --t3: #9c968e; --p: #c17b3c;
            --ff: 'Cabinet Grotesk', sans-serif; --mono: 'JetBrains Mono', monospace;
        }
        body { background: var(--bg); color: var(--t1); font-family: var(--ff); min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; margin: 0; }
        .welcome-card { background: var(--s1); border: 1px solid var(--border); border-radius: 20px; width: 100%; max-width: 800px; min-height: 480px; display: flex; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.04); }
        .brand-side { flex: 1; background: var(--s2); padding: 40px; display: flex; flex-direction: column; border-right: 1px solid var(--border); }
        .logo-box { width: 36px; height: 36px; border-radius: 10px; background: var(--p); display: flex; align-items: center; justify-content: center; margin-bottom: auto; }
        .brand-content h1 { font-size: 40px; font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 16px; }
        .form-side { flex: 1; padding: 50px; display: flex; flex-direction: column; justify-content: center; text-align: center; }
        .form-title { font-size: 26px; font-weight: 700; margin-bottom: 30px; }
        .btn-primary { background: var(--t1); color: #fff; border-radius: 8px; padding: 14px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s; display: inline-block; width: 100%; }
        .btn-primary:hover { background: #2c2820; transform: translateY(-1px); color: #fff; }
    </style>
</head>
<body>
    <div class="welcome-card">
        <div class="brand-side">
            <div class="logo-box">
                <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
                    <rect x="2" y="2" width="5" height="5" rx="1.2" fill="white" opacity=".9"/>
                    <rect x="9" y="2" width="5" height="5" rx="1.2" fill="white" opacity=".6"/>
                    <rect x="2" y="9" width="5" height="5" rx="1.2" fill="white" opacity=".6"/>
                    <rect x="9" y="9" width="5" height="5" rx="1.2" fill="white" opacity=".35"/>
                </svg>
            </div>
            <div class="brand-content">
                <h1>Smart CV<br>Matching.</h1>
            </div>
            <div style="font-size: 10px; color: var(--t3); font-family: var(--mono);">
                © @DateTime.Now.Year OSTIM Technical University Project
            </div>
        </div>

        <div class="form-side">
            <h2 class="form-title">Welcome back</h2>
            
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn-primary" asp-controller="Home" asp-action="Dashboard">Go to Workspace</a>
            }
            else
            {
                <a class="btn-primary" 
                   asp-area="Identity" 
                   asp-page="/Account/Login" 
                   asp-route-returnUrl="@Url.Action("Dashboard", "Home")">Sign In</a>
            }
        </div>
    </div>
</body>
</html>