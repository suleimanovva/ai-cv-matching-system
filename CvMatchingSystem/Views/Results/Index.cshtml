@model IEnumerable<CvMatchingSystem.Models.MatchingResult>

@{
    ViewData["Title"] = "Matching Results History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary"><i class="bi bi-journal-text"></i> Matching Results</h1>
    <span class="badge bg-secondary">Total Records: @Model.Count()</span>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Candidate Name</th>
                    <th>Job Title</th>
                    <th class="text-center">Match Score (%)</th>
                    <th>Date Generated</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fw-bold">
                            @(item.Candidate?.FullName ?? "Unknown Candidate")
                        </td>
                        <td class="align-middle">
                            @(item.JobPosting?.Title ?? "N/A")
                        </td>
                        <td class="text-center align-middle">
                            <span class="badge @(item.Score >= 75 ? "bg-success" : item.Score >= 40 ? "bg-warning text-dark" : "bg-danger") p-2" style="font-size: 0.9rem;">
                                @item.Score%
                            </span>
                        </td>
                        <td class="align-middle text-muted">
                            @item.CreatedDate.ToString("dd MMM yyyy, HH:mm")
                        </td>
                        <td class="text-center align-middle">
                            <div class="btn-group" role="group">
                                <a asp-action="ExportToPdf" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger shadow-sm" title="Export to PDF">
                                    <i class="bi bi-file-earmark-pdf"></i> PDF
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary shadow-sm" 
                                   onclick="return confirm('Are you sure you want to delete this matching result?');">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-info-circle"></i> No matching results found yet. Go to <strong>AI Matcher</strong> to start.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>