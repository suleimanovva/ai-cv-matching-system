@model IEnumerable<CvMatchingSystem.Models.MatchingResult>

@{
    ViewData["Title"] = "Analysis History";
}

<div class="pg-head">
    <div>
        <div class="pg-title">Matching Results</div>
        <div class="pg-meta">@Model.Count() records processed</div>
    </div>
</div>

<div class="card c-table" style="grid-column: span 12;">
    <div class="ch">
        <div class="ch-label">System History Log</div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Candidate</th>
                <th>Position</th>
                <th>Match Score</th>
                <th>Date Generated</th>
                <th style="text-align:right">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <div class="cn">@(item.Candidate?.FullName ?? "Unknown")</div>
                    </td>
                    <td style="color:var(--t3); font-size:11px">
                        @(item.JobPosting?.Title ?? "N/A")
                    </td>
                    <td>
                        <div class="sbar">
                            <div class="strack" style="width: 80px;">
                                <div class="sfill" style="width: @((int)item.Score)%; background: @(item.Score >= 75 ? "var(--green)" : item.Score >= 40 ? "var(--p)" : "var(--red)")"></div>
                            </div>
                            <span class="snum" style="color: @(item.Score >= 75 ? "var(--green)" : item.Score >= 40 ? "var(--p)" : "var(--red)")">
                                @item.Score.ToString("F0")%
                            </span>
                        </div>
                    </td>
                    <td style="color:var(--t3); font-size:11px; font-family:var(--mono);">
                        @item.CreatedDate.ToString("dd MMM yyyy, HH:mm")
                    </td>
                    <td>
                        <div style="display:flex; gap:16px; justify-content: flex-end;">
                            <a asp-action="Details" asp-route-id="@item.Id" class="tact" style="color:var(--p) !important">report</a>
                            <a asp-action="ExportToPdf" asp-route-id="@item.Id" class="tact">pdf</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="tact" style="color:var(--red) !important" 
                                   onclick="return confirm('Confirm deletion?');">delete</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>