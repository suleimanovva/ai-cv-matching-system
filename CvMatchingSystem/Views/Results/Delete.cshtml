@model CvMatchingSystem.Models.MatchingResult

@{
    ViewData["Title"] = "Delete Result";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h3>
                </div>
                <div class="card-body text-center py-4">
                    <p class="lead">Are you sure you want to delete this matching result?</p>
                    <hr />
                    <dl class="row text-start">
                        <dt class="col-sm-5 text-muted">Candidate:</dt>
                        <dd class="col-sm-7 fw-bold">@(Model.Candidate?.FullName ?? "Unknown")</dd>

                        <dt class="col-sm-5 text-muted">Job Title:</dt>
                        <dd class="col-sm-7">@(Model.JobPosting?.Title ?? "N/A")</dd>

                        <dt class="col-sm-5 text-muted">Score:</dt>
                        <dd class="col-sm-7 text-danger fw-bold">@Model.Score%</dd>
                    </dl>
                </div>
                <div class="card-footer d-flex justify-content-center gap-3">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">
                            <i class="bi bi-trash"></i> Yes, Delete
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>