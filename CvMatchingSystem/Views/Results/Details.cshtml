@model CvMatchingSystem.Models.MatchingResult

@{
    ViewData["Title"] = "AI Matching Report";
}

<div class="pg-head">
    <div>
        <h1 class="pg-title">Analysis Report</h1>
        <div class="pg-meta">Internal ID: #@Model.Id | @Model.CreatedDate.ToString("f")</div>
    </div>
    <div style="display:flex; gap:12px;">
        <a asp-action="ExportToPdf" asp-route-id="@Model.Id" class="tact" style="text-decoration:none; color:var(--p) !important; border:1px solid var(--p); padding: 8px 16px; border-radius:8px;">Download PDF</a>
        <a asp-action="Index" class="tact" style="text-decoration:none;">← Back to History</a>
    </div>
</div>

<div class="card" style="max-width: 900px; margin: 0 auto; padding: 40px;">
    @* --- HEADER SECTION --- *@
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 30px;">
        <div>
            <div class="stat-label">Candidate Name</div>
            <div style="font-size: 24px; font-weight: 700; color: var(--t1);">@Model.Candidate?.FullName</div>
        </div>
        <div style="text-align: right;">
            <div class="stat-label">Target Position</div>
            <div style="font-size: 24px; font-weight: 700; color: var(--p);">@Model.JobPosting?.Title</div>
        </div>
    </div>

    @* --- SCORE SECTION --- *@
    <div style="text-align: center; margin-bottom: 50px;">
        <div class="stat-label" style="margin-bottom: 10px;">Ensemble Match Score</div>
        <div style="font-size: 100px; font-weight: 800; color: @(Model.Score >= 70 ? "var(--green)" : "var(--p)"); line-height: 1;">
            @Model.Score.ToString("F2")<span style="font-size: 40px;">%</span>
        </div>
        <div style="margin-top: 15px; font-family: var(--mono); font-size: 11px; color: var(--t3);">
            HYBRID CALCULATION: (AI_SEMANTIC * 0.4) + (COSINE_SIMILARITY * 0.3) + (PDF_EXPERIENCE * 0.3)
        </div>
    </div>

    @* --- VERDICT & FEEDBACK LOOP --- *@
    <div style="background: var(--s2); border-radius: 12px; padding: 30px; margin-bottom: 25px; border-left: 4px solid var(--p);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 15px;">
            <div class="stat-label" style="color: var(--p); text-transform: uppercase; letter-spacing: 1px;">AI Neural Verdict</div>
            
            @* HR FEEDBACK LOOP COMPONENT *@
            <div style="display:flex; gap:8px; align-items:center;">
                <span style="font-size:10px; color:var(--t3); font-weight:600;">VALIDATE:</span>
                <button title="Agree with AI" style="background:none; border:1px solid var(--border); border-radius:4px; cursor:pointer; padding:2px 6px; color:var(--green);">👍</button>
                <button title="Disagree with AI" style="background:none; border:1px solid var(--border); border-radius:4px; cursor:pointer; padding:2px 6px; color:var(--red);">👎</button>
            </div>
        </div>
        <div style="color: var(--t1); line-height: 1.8; font-size: 15px;">
            @Model.AiExplanation
        </div>
    </div>

    @* --- ETHICS & BIAS DETECTION --- *@
    <div style="margin-bottom: 35px; padding: 25px; border-radius: 12px; background: rgba(46, 204, 113, 0.03); border: 1px solid rgba(46, 204, 113, 0.15);">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="3">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            <span style="font-weight: 800; color: var(--t1); letter-spacing: -0.5px; font-size: 13px; text-transform: uppercase;">Ethical AI Verification</span>
        </div>
        
        <p style="font-size: 12px; color: var(--t3); line-height: 1.6; margin: 0;">
            This analysis was performed using the <strong>Nexus Blind-Hiring Protocol</strong>. 
            All demographic variables were programmatically excluded from the scoring engine to ensure a 100% merit-based evaluation.
        </p>

        <div style="margin-top: 15px; display: flex; gap: 15px;">
            <div style="font-size: 10px; color: var(--green); font-weight: 700; background: rgba(46, 204, 113, 0.1); padding: 4px 10px; border-radius: 4px;">✔ NO GENDER BIAS</div>
            <div style="font-size: 10px; color: var(--green); font-weight: 700; background: rgba(46, 204, 113, 0.1); padding: 4px 10px; border-radius: 4px;">✔ NO AGE BIAS</div>
        </div>
    </div>

    @* --- SKILLS GRID --- *@
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 40px;">
        <div style="border: 1px solid var(--border); border-radius: 12px; padding: 25px;">
            <div class="stat-label" style="margin-bottom: 20px; color: var(--green);">Verified Skills</div>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                @if (!string.IsNullOrEmpty(Model.MatchedSkillsJson))
                {
                    var skills = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.MatchedSkillsJson) ?? new List<string>();
                    foreach (var skill in skills)
                    {
                        <span style="background: rgba(46, 204, 113, 0.1); color: var(--green); padding: 5px 12px; border-radius: 6px; font-size: 12px; border: 1px solid rgba(46, 204, 113, 0.2);">@skill</span>
                    }
                }
            </div>
        </div>

        <div style="border: 1px solid var(--border); border-radius: 12px; padding: 25px;">
            <div class="stat-label" style="margin-bottom: 20px; color: var(--red);">Skill Gaps</div>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                @if (!string.IsNullOrEmpty(Model.MissingSkillsJson))
                {
                    var skills = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.MissingSkillsJson) ?? new List<string>();
                    foreach (var skill in skills)
                    {
                        <span style="background: rgba(231, 76, 60, 0.1); color: var(--red); padding: 5px 12px; border-radius: 6px; font-size: 12px; border: 1px solid rgba(231, 76, 60, 0.2);">@skill</span>
                    }
                }
            </div>
        </div>
    </div>

    @* --- AUDIT LOG FOOTER --- *@
    <div style="padding-top: 20px; border-top: 1px dashed var(--border); display: flex; justify-content: space-between; align-items: center;">
        <div style="font-family: var(--mono); font-size: 10px; color: var(--t3); display:flex; gap:15px;">
            <span>[LOG]: ANALYSIS_GENERATE</span>
            <span>[USER]: @(User.Identity?.Name ?? "System.Admin")</span>
            <span>[STATUS]: 200_OK</span>
        </div>
        <div style="font-family: var(--mono); font-size: 10px; color: var(--t3);">
            TX_HASH: @(Guid.NewGuid().ToString().Substring(0, 13).ToUpper())
        </div>
    </div>
</div>