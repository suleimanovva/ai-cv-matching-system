@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus</title>
    <link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@300;400;500;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
    
    <style>
        :root {
            --bg: #f0ede8; --s1: #faf8f5; --s2: #f5f2ed; --s3: #ede9e2;
            --border: #e2ddd6; --border2: #d4cfc7;
            --t1: #1a1714; --t2: #5c5650; --t3: #9c968e;
            --p: #c17b3c; --p2: #d9955a;
            --red: #a33030;
            --ff: 'Cabinet Grotesk', sans-serif;
            --mono: 'JetBrains Mono', monospace;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: var(--bg); color: var(--t1); font-family: var(--ff);
            min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px;
        }
        .welcome-card {
            background: var(--s1); border: 1px solid var(--border); border-radius: 20px;
            width: 100%; max-width: 800px; min-height: 480px; display: flex; overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.04);
        }
        .brand-side {
            flex: 1; background: var(--s2); padding: 40px; display: flex; flex-direction: column; border-right: 1px solid var(--border);
        }
        .logo-wrap { display: flex; align-items: center; gap: 12px; margin-bottom: auto; }
        .logo-box { width: 36px; height: 36px; border-radius: 10px; background: var(--p); display: flex; align-items: center; justify-content: center; }
        .logo-text { font-size: 20px; font-weight: 800; letter-spacing: -0.02em; }
        .brand-content h1 { font-size: 40px; font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 16px; }
        .form-side { flex: 1; padding: 50px; display: flex; flex-direction: column; justify-content: center; }
        .form-title { font-size: 26px; font-weight: 700; margin-bottom: 30px; letter-spacing: -0.01em; text-align: center; }
        
        .input-group { margin-bottom: 20px; }
        .input-label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--t3); margin-bottom: 8px; }
        .nexus-input {
            width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
            padding: 12px 16px; font-family: var(--ff); font-size: 14px; color: var(--t1); transition: all 0.2s; outline: none;
        }
        .nexus-input:focus { border-color: var(--p); background: var(--s1); }
        .btn-primary {
            width: 100%; background: var(--t1); color: #fff; border: none; border-radius: 8px;
            padding: 14px; font-family: var(--ff); font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s;
        }
        .btn-primary:hover { background: #2c2820; transform: translateY(-1px); }
        
        .restricted-note { text-align: center; margin-top: 30px; font-size: 11px; color: var(--t3); font-family: var(--mono); }
        .text-danger { color: var(--red); font-size: 12px; margin-top: 4px; display: block; }
        .validation-summary-errors { color: var(--red); font-size: 13px; margin-bottom: 20px; font-weight: 500; list-style: none; padding: 0; }
    </style>
</head>
<body>
    <div class="welcome-card">
        <div class="brand-side">
            <div class="logo-wrap">
                <div class="logo-box">
                    <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
                        <rect x="2" y="2" width="5" height="5" rx="1.2" fill="white" opacity=".9"/>
                        <rect x="9" y="2" width="5" height="5" rx="1.2" fill="white" opacity=".6"/>
                        <rect x="2" y="9" width="5" height="5" rx="1.2" fill="white" opacity=".6"/>
                        <rect x="9" y="9" width="5" height="5" rx="1.2" fill="white" opacity=".35"/>
                    </svg>
                </div>
                <div class="logo-text">Nexus</div>
            </div>
            <div class="brand-content">
                <h1>Secure<br>Workspace.</h1>
            </div>
            <div style="font-size: 10px; color: var(--t3); font-family: var(--mono); margin-top: auto;">
                © 2026 OSTIM Technical University Project
            </div>
        </div>

        <div class="form-side">
            <h2 class="form-title">Log In</h2>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>
                <div class="input-group">
                    <label asp-for="Input.Email" class="input-label">Email</label>
                    <input asp-for="Input.Email" class="nexus-input" autocomplete="username" aria-required="true" placeholder="name@company.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="input-group">
                    <label asp-for="Input.Password" class="input-label">Password</label>
                    <input asp-for="Input.Password" class="nexus-input" autocomplete="current-password" aria-required="true" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div style="margin-bottom: 24px;">
                    <label asp-for="Input.RememberMe" style="font-size: 13px; color: var(--t2); cursor: pointer; display: flex; align-items: center; gap: 8px;">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="accent-color: var(--p);" />
                        Remember me?
                    </label>
                </div>
                <button id="login-submit" type="submit" class="btn-primary">Authenticate</button>
            </form>
            <div class="restricted-note">
                PRIVATE SYSTEM // AUTHORIZED ACCESS ONLY
            </div>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>